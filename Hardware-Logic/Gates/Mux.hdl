// File name: projects/01/Mux.hdl

/** 
 * Multiplexor:
 * out = a if sel == 0
 *       b otherwise
 */

CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Nand(a=sel,b=sel,out=nots);
    Nand(a=a,b=nots,out=anandnouts);
    Nand(a=sel,b=b,out=bnands);
    Nand(a=anandnouts,b=bnands,out=out);
}