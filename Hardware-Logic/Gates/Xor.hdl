// File name: projects/01/Xor.hdl

/**
 * Exclusive-or gate:
 * out = not (a == b)
 */

CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Nand(a=a,b=a,out=nota);
    Nand(a=b,b=b,out=notb);
    Nand(a=a,b=notb,out=aandnotb);
    Nand(a=nota,b=b,out=notaandb);
    Nand(a=aandnotb,b=notaandb,out=out);

}